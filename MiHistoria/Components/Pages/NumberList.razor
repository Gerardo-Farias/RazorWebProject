@page "/numbList"
@rendermode InteractiveServer

<h3>Listas de números</h3>

<div class="mb-3">
    <label>Número 1</label>
    <input type="number" class="form-control" @bind="num1" />
</div>

<div class="mb-3">
    <label>Número 2</label>
    <input type="number" class="form-control" @bind="num2" />
</div>

<button class="btn btn-primary mb-4" @onclick="Calcular">Calcular</button>

<div class="row">
    <div class="col-md-6">
        <h4>Pares</h4>
        @foreach (var n in pares)
        {
            <div class="form-control mb-2">@n</div>
        }
    </div>

    <div class="col-md-6">
        <h4>Impares</h4>
        @foreach (var n in impares)
        {
            <div class="form-control mb-2">@n</div>
        }
    </div>
</div>

@code {
    private int num1;
    private int num2;

    private List<int> pares = new();
    private List<int> impares = new();

    private void Calcular()
    {
        pares.Clear();
        impares.Clear();

        int inicio = Math.Min(num1, num2);
        int fin = Math.Max(num1, num2);

        for (int i = inicio; i <= fin; i++)
        {
            if (i % 2 == 0)
                pares.Add(i);
            else
                impares.Add(i);
        }
    }
}