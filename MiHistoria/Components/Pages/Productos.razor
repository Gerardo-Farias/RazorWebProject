@page "/productos"
@rendermode InteractiveServer

<h3>
    Gestión de Productos
</h3>

<div class="mb-3">
    <label>ID Inventario:</label>
    <input type="number" class="form-control" @bind="idInventario" />
</div>

<div class="mb-3">
    <label>Nombre del producto:</label>
    <input class="form-control" @bind="nombreProducto" maxlength="200" />
</div>

<div class="mb-3">
    <label>Categoría:</label>
    <select class="form-control" @bind="categoria">
        <option value="">Selecciona</option>
        <option>Frutas</option>
        <option>Verduras</option>
        <option>Lácteos</option>
    </select>
</div>

<div class="mb-3">
    @if (!editando)
    {
        <button class="btn btn-primary" @onclick="AgregarProducto">Agregar</button>
    }
    else
    {
        <button class="btn btn-success me-2" @onclick="GuardarCambios">Guardar cambios</button>
        <button class="btn btn-secondary" @onclick="CancelarEdicion">Cancelar</button>
    }

    <button class="btn ms-2 @(vistaActual == Vista.Resumen ? "btn-light text-dark" : "btn-primary")"
            @onclick="MostrarResumen">
        Existencias
    </button>

    <button class="btn ms-2 @(vistaActual == Vista.Lista ? "btn-light text-dark" : "btn-primary")"
            @onclick="MostrarLista">
        Listado
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(mensajeError))
{
    <p class="text-danger">@mensajeError</p>
}

@if (vistaActual == Vista.Lista)
{
    @if (listaProductos.Any())
    {
        <table class="table mt-4">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in listaProductos)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nombre</td>
                        <td>@item.Categoria</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => IniciarEdicion(item)">
                                Editar
                            </button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => BorrarProducto(item)">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else if (vistaActual == Vista.Resumen)
{
    <h5 class="mt-4">Resumen por categoría</h5>
    <ul>
        <li>Frutas: @ContarPorCategoria("Frutas")</li>
        <li>Verduras: @ContarPorCategoria("Verduras")</li>
        <li>Lácteos: @ContarPorCategoria("Lácteos")</li>
    </ul>
}

@code {

    int idInventario;
    string nombreProducto = string.Empty;
    string categoria = string.Empty;
    string mensajeError = string.Empty;

    bool editando = false;
    Producto? productoActual;

    List<Producto> listaProductos = new();

    Vista vistaActual = Vista.Lista;

    enum Vista
    {
        Lista,
        Resumen
    }

    void AgregarProducto()
    {
        if (!ValidarDatos()) return;

        if (ExisteIdDuplicado(idInventario))
        {
            mensajeError = "ID ya registrado";
            return;
        }

        listaProductos.Add(new Producto
        {
            Id = idInventario,
            Nombre = nombreProducto,
            Categoria = categoria
        });

        ResetFormulario();
    }

    void BorrarProducto(Producto prod)
    {
        listaProductos.Remove(prod);
    }

    void IniciarEdicion(Producto prod)
    {
        editando = true;
        productoActual = prod;

        idInventario = prod.Id;
        nombreProducto = prod.Nombre;
        categoria = prod.Categoria;
    }

    void GuardarCambios()
    {
        if (!ValidarDatos()) return;

        if (ExisteIdDuplicado(idInventario, productoActual))
        {
            mensajeError = "ID duplicado";
            return;
        }

        productoActual!.Id = idInventario;
        productoActual.Nombre = nombreProducto;
        productoActual.Categoria = categoria;

        CancelarEdicion();
    }

    void CancelarEdicion()
    {
        editando = false;
        productoActual = null;
        ResetFormulario();
    }

    void MostrarResumen() => vistaActual = Vista.Resumen;

    void MostrarLista() => vistaActual = Vista.Lista;

    bool ValidarDatos()
    {
        mensajeError = "";

        if (idInventario <= 0 ||
            string.IsNullOrWhiteSpace(nombreProducto) ||
            string.IsNullOrWhiteSpace(categoria))
        {
            mensajeError = "Campos inválidos";
            return false;
        }

        return true;
    }

    bool ExisteIdDuplicado(int id, Producto? ignorar = null)
    {
        return listaProductos.Any(p => p.Id == id && p != ignorar);
    }

    int ContarPorCategoria(string cat)
    {
        return listaProductos.Count(p => p.Categoria == cat);
    }

    void ResetFormulario()
    {
        idInventario = 0;
        nombreProducto = "";
        categoria = "";
        mensajeError = "";
    }

    class Producto
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = "";
        public string Categoria { get; set; } = "";
    }
}